    <script>
        // ============ DATABAS (SQL.js) ============
        let db = null;
        let databaseInitialized = false;
        
        // Initiera databasen
        async function initDatabase() {
            return new Promise((resolve) => {
                const SQL = window.SQL;
                if (!SQL) {
                    setTimeout(() => initDatabase().then(resolve), 100);
                    return;
                }
                
                db = new SQL.Database();
                
                // Skapa tabeller
                db.run(`CREATE TABLE IF NOT EXISTS sales_history (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    day TEXT,
                    hour INTEGER,
                    orders INTEGER,
                    date TEXT
                )`);
                
                db.run(`CREATE TABLE IF NOT EXISTS staff_log (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    day TEXT,
                    hour INTEGER,
                    kitchen INTEGER,
                    front_counter INTEGER,
                    drive_thru INTEGER,
                    delivery INTEGER,
                    date TEXT
                )`);
                
                db.run(`CREATE TABLE IF NOT EXISTS restaurant_settings (
                    key TEXT PRIMARY KEY,
                    value TEXT
                )`);
                
                // Lägg in exempeldata om databasen är tom
                const count = db.exec("SELECT COUNT(*) FROM sales_history");
                if (!count[0] || count[0].values[0][0] === 0) {
                    // Generera historisk data för 6 veckor
                    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
                    for (let week = 0; week < 6; week++) {
                        for (let d of days) {
                            let multiplier = (d === 'Fri' || d === 'Sat') ? 1.45 : (d === 'Sun' ? 1.2 : 1);
                            for (let hour = 6; hour <= 23; hour++) {
                                let baseOrders = 40;
                                if (hour >= 12 && hour <= 15) baseOrders = 100;
                                else if (hour >= 18 && hour <= 21) baseOrders = 90;
                                else if (hour >= 8 && hour <= 10) baseOrders = 55;
                                let orders = Math.round(baseOrders * multiplier * (0.85 + Math.random() * 0.3));
                                let date = `2026-01-${String(week+1).padStart(2,'0')}`;
                                db.run(`INSERT INTO sales_history (day, hour, orders, date) VALUES (?, ?, ?, ?)`, [d, hour, orders, date]);
                            }
                        }
                    }
                }
                
                databaseInitialized = true;
                updateDatabaseStats();
                resolve();
            });
        }
        
        function updateDatabaseStats() {
            if (!db) return;
            const countResult = db.exec("SELECT COUNT(*) FROM sales_history");
            const records = countResult[0]?.values[0][0] || 0;
            document.getElementById('dbRecords').innerHTML = records;
            document.getElementById('dataWeeks').innerHTML = Math.floor(records / 126) || 6;
            document.getElementById('accuracy').innerHTML = (90 + Math.random() * 5).toFixed(1) + '%';
            document.getElementById('avgWaitTime').innerHTML = Math.floor(3 + Math.random() * 3) + ' min';
        }
        
        // Hämta prognos från databasen + AI
        function getForecastFromDatabase(day) {
            if (!db) return getMockForecast(day);
            
            // Hämta historiska data för samma veckodag
            const result = db.exec(`SELECT hour, AVG(orders) as avg_orders FROM sales_history WHERE day = '${day}' GROUP BY hour ORDER BY hour`);
            const forecast = [];
            
            for (let hour = 6; hour <= 23; hour++) {
                let orders = 50;
                const found = result[0]?.values.find(row => row[0] === hour);
                if (found) {
                    orders = Math.round(found[1]);
                } else {
                    // Default baserat på tid på dagen
                    if (hour >= 12 && hour <= 15) orders = 95;
                    else if (hour >= 18 && hour <= 21) orders = 85;
                    else if (hour >= 8 && hour <= 10) orders = 55;
                }
                forecast.push({ hour, orders });
            }
            return forecast;
        }
        
        function getMockForecast(day) {
            let multiplier = (day === 'Fri' || day === 'Sat') ? 1.45 : (day === 'Sun' ? 1.2 : 1);
            const data = [];
            for (let hour = 6; hour <= 23; hour++) {
                let baseOrders = 40;
                if (hour >= 12 && hour <= 15) baseOrders = 100;
                else if (hour >= 18 && hour <= 21) baseOrders = 90;
                else if (hour >= 8 && hour <= 10) baseOrders = 55;
                let orders = Math.round(baseOrders * multiplier * (0.9 + Math.random() * 0.2));
                data.push({ hour, orders });
            }
            return data;
        }
        
        // Beräkna personalbehov
        function calculateStaff(orders) {
            return {
                kitchen: Math.max(1, Math.round(orders / 25)),
                frontCounter: Math.max(1, Math.round(orders / 30)),
                driveThru: Math.max(1, Math.round(orders / 35)),
                delivery: Math.max(1, Math.round(orders / 40)),
                total: Math.max(4, Math.round(orders / 8))
            };
        }
        
        // Variabler
        let currentDay = 'Mon';
        let ordersChart;
        
        function getDayName(day) {
            const names = { 'Mon': 'Måndag', 'Tue': 'Tisdag', 'Wed': 'Onsdag', 'Thu': 'Torsdag', 'Fri': 'Fredag', 'Sat': 'Lördag', 'Sun': 'Söndag' };
            return names[day];
        }
        
        function updateDashboard() {
            const forecast = getForecastFromDatabase(currentDay);
            const totalOrders = forecast.reduce((sum, h) => sum + h.orders, 0);
            
            // Beräkna personal för varje timme och summera
            let totalStaffSum = 0;
            let peakHoursList = [];
            let avgStaff = { kitchen: 0, frontCounter: 0, driveThru: 0, delivery: 0 };
            
            forecast.forEach(h => {
                const staff = calculateStaff(h.orders);
                totalStaffSum += staff.total;
                avgStaff.kitchen += staff.kitchen;
                avgStaff.frontCounter += staff.frontCounter;
                avgStaff.driveThru += staff.driveThru;
                avgStaff.delivery += staff.delivery;
                if (h.orders > 80) peakHoursList.push(`${h.hour}:00`);
            });
            
            const hoursCount = forecast.length;
            const avgTotalStaff = Math.round(totalStaffSum / hoursCount);
            const avgKitchen = Math.round(avgStaff.kitchen / hoursCount);
            const avgFront = Math.round(avgStaff.frontCounter / hoursCount);
            const avgDrive = Math.round(avgStaff.driveThru / hoursCount);
            const avgDelivery = Math.round(avgStaff.delivery / hoursCount);
            
            const efficiency = Math.min(100, Math.round((totalOrders / hoursCount / 70) * 100));
            
            document.getElementById('totalOrders').innerHTML = totalOrders.toLocaleString();
            document.getElementById('totalStaff').innerHTML = avgTotalStaff;
            document.getElementById('efficiency').innerHTML = efficiency;
            document.getElementById('peakHours').innerHTML = peakHoursList.length ? peakHoursList.join(' - ') : 'Inga rusningstider';
            
            document.getElementById('staffKitchen').innerHTML = avgKitchen;
            document.getElementById('staffFront').innerHTML = avgFront;
            document.getElementById('staffDrive').innerHTML = avgDrive;
            document.getElementById('staffDelivery').innerHTML = avgDelivery;
            
            // Uppdatera tabell
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            forecast.forEach(h => {
                const staff = calculateStaff(h.orders);
                const row = tbody.insertRow();
                row.insertCell(0).innerHTML = `${h.hour}:00`;
                row.insertCell(1).innerHTML = `${h.orders} st`;
                row.insertCell(2).innerHTML = `${staff.total} st`;
                row.insertCell(3).innerHTML = h.orders > 80 ? '<span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold">🔴 RUSNING</span>' : '<span class="bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs font-bold">🟢 Normal</span>';
            });
            
            // Uppdatera diagram
            if (ordersChart) ordersChart.destroy();
            const ctx = document.getElementById('ordersChart').getContext('2d');
            ordersChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: forecast.map(h => `${h.hour}:00`),
                    datasets: [{
                        label: 'Förväntade beställningar',
                        data: forecast.map(h => h.orders),
                        borderColor: '#da291c',
                        backgroundColor: 'rgba(218, 41, 28, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: forecast.map(h => h.orders > 80 ? '#ff4757' : '#da291c'),
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { position: 'top' }
                    }
                }
            });
            
            // AI Meddelande
            const avgOrders = Math.round(totalOrders / hoursCount);
            const aiMsg = peakHoursList.length > 0 
                ? `🤖 Smart Shift AI analys: För ${getDayName(currentDay)} förväntas rusning klockan ${peakHoursList.join(', ')}. Rekommenderar ${avgTotalStaff} medarbetare per timme med fokus på kök (${avgKitchen} pers) och front (${avgFront} pers). Öka beredskapen 30 minuter före rusning.`
                : `🤖 Smart Shift AI analys: ${getDayName(currentDay)} har inga kraftiga rusningstider. Rekommenderar ${Math.max(3, avgTotalStaff-1)} medarbetare per timme. Använd lugna perioder för utbildning och förberedelser.`;
            
            document.getElementById('aiMessage').innerHTML = `<div class="flex items-start gap-3"><i class="fas fa-microphone-alt text-red-500 text-xl mt-1"></i><p class="text-gray-700 leading-relaxed">${aiMsg}</p></div>`;
            
            // Uppdatera larm
            const alertsDiv = document.getElementById('alertsList');
            let alertsHtml = '';
            if (peakHoursList.length > 0) {
                alertsHtml += `<div class="flex items-start gap-3 p-3 bg-orange-50 rounded-lg border-l-4 border-orange-500">
                    <i class="fas fa-exclamation-triangle text-orange-500 mt-1"></i>
                    <div><p class="font-bold text-orange-800">🚨 RUSNINGSVARNING!</p>
                    <p class="text-sm text-orange-600">Förväntad hög belastning klockan ${peakHoursList.join(', ')}. Planera för extra personal!</p></div>
                </div>`;
            }
            if (avgOrders < 50) {
                alertsHtml += `<div class="flex items-start gap-3 p-3 bg-blue-50 rounded-lg border-l-4 border-blue-500">
                    <i class="fas fa-info-circle text-blue-500 mt-1"></i>
                    <div><p class="font-bold text-blue-800">ℹ️ Låg belastning</p>
                    <p class="text-sm text-blue-600">Förväntad låg belastning. Möjlighet att minska personalstyrkan.</p></div>
                </div>`;
            }
            if (alertsHtml === '') {
                alertsHtml = `<div class="flex items-start gap-3 p-3 bg-green-50 rounded-lg border-l-4 border-green-500">
                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                    <div><p class="font-bold text-green-800">✅ Inga aktiva larm</p>
                    <p class="text-sm text-green-600">Allt ser bra ut. Bra planerat!</p></div>
                </div>`;
            }
            alertsDiv.innerHTML = alertsHtml;
        }
        
        // Synkronisera data
        document.getElementById('syncDataBtn')?.addEventListener('click', function() {
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Synkroniserar...';
            setTimeout(() => {
                if (db) {
                    // Lägg till ny data
                    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
                    const newDate = new Date().toISOString().split('T')[0];
                    for (let d of days) {
                        let multiplier = (d === 'Fri' || d === 'Sat') ? 1.45 : (d === 'Sun' ? 1.2 : 1);
                        for (let hour = 6; hour <= 23; hour++) {
                            let baseOrders = 40;
                            if (hour >= 12 && hour <= 15) baseOrders = 100;
                            else if (hour >= 18 && hour <= 21) baseOrders = 90;
                            let orders = Math.round(baseOrders * multiplier * (0.85 + Math.random() * 0.3));
                            db.run(`INSERT INTO sales_history (day, hour, orders, date) VALUES (?, ?, ?, ?)`, [d, hour, orders, newDate]);
                        }
                    }
                    updateDatabaseStats();
                }
                updateDashboard();
                this.innerHTML = '<i class="fas fa-check"></i> Synkroniserad!';
                setTimeout(() => {
                    this.innerHTML = '<i class="fas fa-sync-alt"></i> Synkronisera data från restaurangen';
                }, 2000);
            }, 1500);
        });
        
        // Dag knappar
        document.querySelectorAll('.day-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.day-btn').forEach(b => {
                    b.classList.remove('bg-red-600', 'text-white');
                    b.classList.add('bg-gray-200', 'text-gray-700');
                });
                this.classList.remove('bg-gray-200', 'text-gray-700');
                this.classList.add('bg-red-600', 'text-white');
                currentDay = this.getAttribute('data-day');
                updateDashboard();
            });
            if (btn.getAttribute('data-day') === 'Mon') {
                btn.classList.remove('bg-gray-200', 'text-gray-700');
                btn.classList.add('bg-red-600', 'text-white');
            } else {
                btn.classList.add('bg-gray-200', 'text-gray-700');
            }
        });
        
        // Datum
        const today = new Date();
        document.getElementById('currentDate').innerHTML = today.toLocaleDateString('sv-SE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        
        // Starta allt
        initDatabase().then(() => {
            updateDashboard();
        });
    </script>
</body>
</html>
